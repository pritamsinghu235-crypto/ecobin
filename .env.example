# Supabase — client-safe (publishable / anon) credentials.
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# IoT device fleet credential — must match the row seeded in
# supabase/migrations/0003_device_simulator.sql (private.device_credentials).
DEVICE_INGEST_KEY=dev_sim_xxx
INGEST_BASE_URL=http://localhost:3000
